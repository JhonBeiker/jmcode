---
import { navLinks, socialLinks } from '../data/navigation.js';
import { contact } from '../data/contact.js';
---

<footer class="border-t border-brand-black/10 bg-white px-4 py-12 sm:px-6 lg:px-8 dark:border-white/10 dark:bg-brand-black">
	<div class="mx-auto flex max-w-6xl flex-col items-center gap-10 text-center md:flex-row md:items-start md:justify-between md:text-left">
		<a href="#hero">
			<img src="/logo_light.png" alt="JMcode" class="mx-auto h-12 w-auto md:mx-0 dark:hidden" />
			<img src="/logo.png" alt="JMcode" class="mx-auto hidden h-12 w-auto md:mx-0 dark:block" />
		</a>

		<nav class="flex flex-wrap justify-center gap-4 md:gap-6">
			{navLinks.map((link) => (
				<a href={link.href} class="font-sans text-sm text-brand-black transition-colors hover:text-brand-orange dark:text-white">
					{link.label}
				</a>
			))}
		</nav>

		<div>
			<p class="font-sans text-sm text-brand-black/80 dark:text-white/80">WhatsApp: {contact.whatsappNumber}</p>
			<p class="font-sans text-sm text-brand-black/80 dark:text-white/80">contacto@jmcode.com</p>

			<div class="mt-4 flex justify-center gap-4 md:justify-start">
				{socialLinks.map((social) => (
					<a
						href={social.href}
						aria-label={social.name}
						class="text-brand-black transition-colors hover:text-brand-orange dark:text-white"
					>
						{social.name === 'Instagram' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
								<rect x="3" y="3" width="18" height="18" rx="5" />
								<circle cx="12" cy="12" r="4" />
								<circle cx="17" cy="7" r="1" fill="currentColor" stroke="none" />
							</svg>
						)}
						{social.name === 'Facebook' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
								<path d="M14 9h2V6h-2c-1.7 0-3 1.3-3 3v2H9v3h2v6h3v-6h2.2l.8-3H14V9z" />
							</svg>
						)}
						{social.name === 'LinkedIn' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5">
								<rect x="3" y="3" width="18" height="18" rx="2" />
								<line x1="7" y1="10" x2="7" y2="16" />
								<circle cx="7" cy="7" r="0.8" fill="currentColor" stroke="none" />
								<path d="M11 16v-4a2 2 0 0 1 4 0v4" />
								<line x1="11" y1="10" x2="11" y2="16" />
							</svg>
						)}
					</a>
				))}
			</div>
		</div>
	</div>

	<p class="mt-10 text-center font-sans text-xs text-brand-black/60">
		© {new Date().getFullYear()} JMcode. Todos los derechos reservados.
	</p>
</footer>
