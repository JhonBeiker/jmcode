---
import { contact } from '../data/contact.js';
import { services } from '../data/services.js';
---

<section id="contacto" class="px-4 py-20 sm:px-6 lg:px-8 dark:bg-brand-black">
	<div class="mx-auto max-w-xl">
		<h2 class="font-heading text-center text-4xl font-bold uppercase text-brand-black sm:text-5xl dark:text-white">
			Hablemos de tu <span class="text-brand-orange">proyecto</span>
		</h2>
		<p class="mt-4 text-center font-sans text-brand-black/80 dark:text-white/80">
			Cuéntanos sobre tu idea y te responderemos por WhatsApp.
		</p>

		<form id="contact-form" class="mt-10 space-y-5" data-whatsapp-number={contact.whatsappNumber}>
			<div>
				<label for="nombre" class="block font-sans text-sm font-medium text-brand-black dark:text-white">Nombre</label>
				<input
					type="text"
					id="nombre"
					name="nombre"
					required
					class="mt-1 w-full rounded-md border border-brand-black/20 px-3 py-2 font-sans focus:border-brand-orange focus:outline-none dark:border-white/20 dark:bg-white/5 dark:text-white"
				/>
			</div>

			<div>
				<label for="servicio" class="block font-sans text-sm font-medium text-brand-black dark:text-white">
					Servicio de interés
				</label>
				<select
					id="servicio"
					name="servicio"
					required
					class="mt-1 w-full rounded-md border border-brand-black/20 px-3 py-2 font-sans focus:border-brand-orange focus:outline-none dark:border-white/20 dark:bg-white/5 dark:text-white"
				>
					<option value="" disabled selected>Selecciona un servicio</option>
					{services.map((service) => (
						<option value={service.title}>{service.title}</option>
					))}
					<option value="Otro">Otro</option>
				</select>
			</div>

			<div>
				<label for="mensaje" class="block font-sans text-sm font-medium text-brand-black dark:text-white">Mensaje</label>
				<textarea
					id="mensaje"
					name="mensaje"
					rows="4"
					required
					class="mt-1 w-full rounded-md border border-brand-black/20 px-3 py-2 font-sans focus:border-brand-orange focus:outline-none dark:border-white/20 dark:bg-white/5 dark:text-white"
				></textarea>
			</div>

			<button
				type="submit"
				class="w-full rounded-md bg-brand-orange px-6 py-3 font-sans text-base font-semibold text-white transition-opacity hover:opacity-90"
			>
				Enviar por WhatsApp
			</button>
		</form>
	</div>
</section>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement | null;

	form?.addEventListener('submit', (event) => {
		event.preventDefault();

		const formData = new FormData(form);
		const nombre = formData.get('nombre');
		const servicio = formData.get('servicio');
		const mensaje = formData.get('mensaje');
		const whatsappNumber = (form.dataset.whatsappNumber ?? '').replace(/\D/g, '');

		const text = `Hola, soy ${nombre}. Estoy interesado en: ${servicio}.\n\n${mensaje}`;
		const url = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(text)}`;

		window.open(url, '_blank');
	});
</script>
